{
  "manifest_version": 3,
  "name": "New API 使用日志导出",
  "version": "1.1.0",
  "description": "为任意 New API 部署的使用日志页面提供账单导出功能",
  "content_scripts": [
    {
      "matches": ["*://*/console/log*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["*://*/*"]
}
